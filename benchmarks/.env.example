# benchmarks/.env is OPTIONAL.
#
# Default (no .env at all): the script runs its own throwaway Postgres container
# (postgres:16-alpine, bound to 127.0.0.1:5544, password "bench") — nothing to fill in.
# Tear it down afterwards with: docker rm -f apitap-bench-pg

# --- benchmark shape -----------------------------------------------------------------
#ROWS=1000000
#WITH_INGESTR=1
# Resource cap per tool (each runs inside its own docker container with these limits).
#CAP_CPUS=2
#CAP_MEM=2g
# Port for the bench Postgres container.
#PGPORT=5544

# --- OR benchmark against an EXISTING Postgres instead --------------------------------
# NOTE: the password lands inside a connection URI, so avoid characters that need
# URL-encoding (@ : / # ?) or encode them yourself. Needs psql on the host.
#PG_DOCKER=0
#PGHOST=127.0.0.1
#PGPORT=5432
#PGUSER=postgres
#PGPASSWORD=changeme
#SRC_DB=apitap_bench_src
#DST_DB=apitap_bench_dst
